# Runtime mode
APP_MODE=dev

# Tickertape screener
TICKERTAPE_BASE_URL=https://api.tickertape.in
TICKERTAPE_TIMEOUT_SECONDS=20
TICKERTAPE_PAGE_SIZE=500

# Universe and scheduling
MAX_STOCKS=100
SCHEDULE_INTERVAL_MINUTES=60

# Strategy thresholds
MIN_SIGNAL_SCORE=3
MAX_PE=40
MIN_PROMOTER_HOLDING=35
MIN_REVENUE_GROWTH=0
MIN_PROFIT_GROWTH=0
SELL_SIGNAL_SCORE=1
STOP_LOSS_PCT=0.15
TAKE_PROFIT_PCT=0.35

# Production broker (Dhan)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_BASE_URL=https://api.dhan.co

# Storage
SQLITE_PATH=stocks_analyser.db
