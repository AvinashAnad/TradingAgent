# Runtime mode
# Use dev for paper execution + API health checks, prod for live order attempts.
APP_MODE=dev

# Tickertape screener
TICKERTAPE_BASE_URL=https://api.tickertape.in
TICKERTAPE_TIMEOUT_SECONDS=20
TICKERTAPE_PAGE_SIZE=500

# Universe and scheduling
MAX_STOCKS=100
SCHEDULE_INTERVAL_MINUTES=60

# Strategy thresholds
MIN_SIGNAL_SCORE=3
MAX_PE=40
MIN_PROMOTER_HOLDING=35
MIN_REVENUE_GROWTH=0
MIN_PROFIT_GROWTH=0
SELL_SIGNAL_SCORE=1
STOP_LOSS_PCT=0.15
TAKE_PROFIT_PCT=0.35

# Production broker (Dhan)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_BASE_URL=https://api.dhan.co
DHAN_HEALTH_ENDPOINT=/fundlimit
DHAN_ORDER_ENDPOINT=/orders
DHAN_EXCHANGE_SEGMENT=NSE_EQ
DHAN_PRODUCT_TYPE=CNC
DHAN_ORDER_TYPE=MARKET
DHAN_VALIDITY=DAY
# JSON map for live trading in prod mode, e.g. {"TCS":"11536","INFY":"1594"}
DHAN_SYMBOL_SECURITY_MAP={}
DEFAULT_TRADE_QUANTITY=1

# Optional LLM cross-check (NVIDIA build.nvidia.com / integrate.api.nvidia.com)
# Modes: off, audit_only
LLM_CROSSCHECK_MODE=off
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_TIMEOUT_SECONDS=20
NVIDIA_TEMPERATURE=0.1
NVIDIA_MAX_TOKENS=300

# Storage
SQLITE_PATH=stocks_analyser.db
